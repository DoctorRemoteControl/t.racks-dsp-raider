  "uncertainty": [
    {
      "scope": "${channelScope}.${channelName}.peq.band${band}.*",
      "reason": "The table structure is visible, but exact edit behavior of each PEQ table cell cannot be proven from the screenshot alone."
    },
    {
      "scope": "${channelScope}.${channelName}.peq.selected_band",
      "reason": "The selected PEQ band can be inferred visually, but should be treated as runtime state, not as a fixed template value."
    },
    {
      "scope": "${channelScope}.${channelName}.*.bypass",
      "reason": "Buttons labeled Bypass are visible, but the screenshot alone does not prove whether the red styling means enabled, disabled, or bypass-active state."
    },
    {
      "scope": "${channelScope}.${channelName}.mode",
      "reason": "The visible Normal button likely represents polarity/phase state, but that cannot be proven from the screenshot alone."
    }
