let base = "out/read-decode/out8-highpass-slope-compare";

# Replace these two payloads with two real captured Out8 HighPass slope endpoints.
# Keep channel, frequency and bypass fixed so only slope/family changes.
let beforeHex = "00 01 05 32 0B 00 00 00";
let afterHex = "00 01 05 32 0B 00 00 00";

connect();
resetSession();
ensureSession();
handshake();

for (let i in 0..28) {
    write(beforeHex);
    sleep(150);
    let before = readBlock(i);

    write(afterHex);
    sleep(150);
    let after = readBlock(i);

    let offsets = changedOffsets(before.payload, after.payload);
    if (len(offsets) > 0) {
        saveText("${base}/block-${i}-before.hex.txt", before.payloadHex);
        saveText("${base}/block-${i}-after.hex.txt", after.payloadHex);
        saveText("${base}/block-${i}-changed-offsets.txt", offsets);
        saveText("${base}/block-${i}-diff-bytes.txt", diffBytes(before.payload, after.payload));
        saveText("${base}/block-${i}-diff-u16le.txt", diffU16le(before.payload, after.payload));
        saveDiffReport("${base}/block-${i}-diff-report.txt", before.payload, after.payload);
        print("out8-highpass-slope changed-block ${i}");
        print(offsets);
    }
}

print("out8-highpass-slope-read-decode-done");
