let tag = "out8-highpass-bypass-toggle";

guiConnect();

let cap = guiActionCapture(
    "Select Out8 on the Channel page. HighPass bypass is currently OFF. Now click only the HighPass bypass control once.",
    45000,
    2000,
    10000
);

let series = writesByCommandAndChannel(cap, 0x32, 0x0B);
let last = lastWriteExcluding(cap, 0x40);
let recent = recentWritesExcluding(cap, 16, 0x40);

saveText("out/clean/${tag}/summary.txt",
    "tag=${tag}\n"
    + "frames=" + cap.totalFrames + "\n"
    + "writes=" + cap.writeCount + "\n"
    + "responses=" + cap.responseCount + "\n"
    + "seriesCount=" + len(series) + "\n"
    + "lastInteresting=" + last + "\n"
    + "assumption=bypass_started_off\n"
);

saveText("out/clean/${tag}/last-write.txt", last);
saveText("out/clean/${tag}/recent-interesting-writes.txt", recent);
saveText("out/clean/${tag}/payload-series.txt", payloadSeries(series));
saveText("out/clean/${tag}/changing-offsets.txt", changingOffsetsAcrossWrites(series));
saveText("out/clean/${tag}/u16-at-5.txt", u16Series(series, 5));
saveText("out/clean/${tag}/note.txt",
    "Out8 HighPass bypass toggle capture.\n"
    + "Expected command: 0x32\n"
    + "Expected channel: 0x0B\n"
    + "Interpretation goal: verify whether bypass uses raw mode 0x00.\n"
);

print("done");
print(last);
print("seriesCount=" + len(series));
print(changingOffsetsAcrossWrites(series));
