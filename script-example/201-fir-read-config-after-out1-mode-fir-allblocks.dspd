saveText("${base}/block-1C.hex.txt", b1C.payloadHex);
saveText("${base}/block-1D.hex.txt", b1D.payloadHex);
saveText("${base}/block-1E.hex.txt", b1E.payloadHex);
saveText("${base}/block-1F.hex.txt", b1F.payloadHex);

saveText("${base}/block-00.ascii.txt", b00.payloadAscii);
saveText("${base}/block-0B.ascii.txt", b0B.payloadAscii);
saveText("${base}/block-1D.ascii.txt", b1D.payloadAscii);
