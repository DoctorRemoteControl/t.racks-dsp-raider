let tag = "fir-read-config-after-out1-mode-fir";
let base = "out/fir/${tag}";

connect();
resetSession();
ensureSession();
handshake();

let b00 = write("00 01 02 27 00", 0x24);
let b01 = write("00 01 02 27 01", 0x24);
let b02 = write("00 01 02 27 02", 0x24);
let b03 = write("00 01 02 27 03", 0x24);
let b04 = write("00 01 02 27 04", 0x24);
let b05 = write("00 01 02 27 05", 0x24);
let b06 = write("00 01 02 27 06", 0x24);
let b07 = write("00 01 02 27 07", 0x24);
