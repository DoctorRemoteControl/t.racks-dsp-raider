let b09 = write("00 01 02 27 09", 0x24);
let b0A = write("00 01 02 27 0A", 0x24);
let b0B = write("00 01 02 27 0B", 0x24);
let b0C = write("00 01 02 27 0C", 0x24);
let b0D = write("00 01 02 27 0D", 0x24);
let b0E = write("00 01 02 27 0E", 0x24);
let b0F = write("00 01 02 27 0F", 0x24);
let b10 = write("00 01 02 27 10", 0x24);
let b11 = write("00 01 02 27 11", 0x24);
let b12 = write("00 01 02 27 12", 0x24);
let b13 = write("00 01 02 27 13", 0x24);
let b14 = write("00 01 02 27 14", 0x24);
let b15 = write("00 01 02 27 15", 0x24);
let b16 = write("00 01 02 27 16", 0x24);
let b17 = write("00 01 02 27 17", 0x24);
let b18 = write("00 01 02 27 18", 0x24);
let b19 = write("00 01 02 27 19", 0x24);
let b1A = write("00 01 02 27 1A", 0x24);
let b1B = write("00 01 02 27 1B", 0x24);
let b1C = write("00 01 02 27 1C", 0x24);
let b1D = write("00 01 02 27 1D", 0x24);
let b1E = write("00 01 02 27 1E", 0x24);
let b1F = write("00 01 02 27 1F", 0x24);

saveText("${base}/block-00.hex.txt", b00.payloadHex);
saveText("${base}/block-01.hex.txt", b01.payloadHex);
saveText("${base}/block-02.hex.txt", b02.payloadHex);
saveText("${base}/block-03.hex.txt", b03.payloadHex);
saveText("${base}/block-04.hex.txt", b04.payloadHex);
saveText("${base}/block-05.hex.txt", b05.payloadHex);
saveText("${base}/block-06.hex.txt", b06.payloadHex);
