saveText("${base}/block-0A.hex.txt", b0A.payloadHex);
saveText("${base}/block-0B.hex.txt", b0B.payloadHex);
saveText("${base}/block-0C.hex.txt", b0C.payloadHex);
saveText("${base}/block-0D.hex.txt", b0D.payloadHex);
saveText("${base}/block-0E.hex.txt", b0E.payloadHex);
saveText("${base}/block-0F.hex.txt", b0F.payloadHex);
saveText("${base}/block-10.hex.txt", b10.payloadHex);
saveText("${base}/block-11.hex.txt", b11.payloadHex);
saveText("${base}/block-12.hex.txt", b12.payloadHex);
saveText("${base}/block-13.hex.txt", b13.payloadHex);
