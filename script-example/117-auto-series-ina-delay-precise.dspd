let tag = "ina-delay-precise";

guiConnect();

let cap = guiActionCapture(
    "Move only the InA delay fader slowly across multiple positions now. Leave the unit on ms.",
    45000,
    1200,
    6000
);

let last = lastWriteExcluding(cap, 0x40);
let recent = recentWritesExcluding(cap, 24, 0x40);

saveText("out/fader/${tag}/summary.txt",
    "tag=${tag}\n"
    + "frames=" + cap.totalFrames + "\n"
    + "writes=" + cap.writeCount + "\n"
    + "responses=" + cap.responseCount + "\n"
    + "lastInteresting=" + last + "\n"
);

saveText("out/fader/${tag}/last-write.txt", last);
saveText("out/fader/${tag}/recent-interesting-writes.txt", recent);

print("done");
print(last);
