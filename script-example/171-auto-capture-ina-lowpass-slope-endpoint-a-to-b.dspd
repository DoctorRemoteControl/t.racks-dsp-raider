let tag = "ina-lowpass-slope-a-to-b";
let base = "out/clean/${tag}";

guiConnect();
let cap = guiActionCapture(
    "Select InA on the Channel page. Start with LowPass slope at one endpoint, then switch only once to the opposite endpoint now.",
    45000,
    1200,
    6000
);

let last = lastWriteExcluding(cap, 0x40);
let recent = recentWritesExcluding(cap, 16, 0x40);

saveText("${base}/capture.txt", cap);
saveText("${base}/last-write.txt", last);
saveText("${base}/recent-interesting-writes.txt", recent);

print("done");
print(last);
