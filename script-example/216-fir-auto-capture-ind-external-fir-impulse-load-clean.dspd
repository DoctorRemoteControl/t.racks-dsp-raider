let tag = "fir-ind-external-fir-impulse-load-clean";

guiConnect();

let cap = guiActionCapture(
    "Set exactly InD FIR Type to External FIR, load C:\\Users\\XLA\\DSP408\\tracks-dsp-raider\\fir-test-files\\fir_512_impulse_first.txt, click OK if needed, then stop touching the GUI.",
    120000,
    4000,
    45000
);

let last = lastWriteExcluding(cap, 0x40);
let recent = recentWritesExcluding(cap, 600, 0x40);

saveText("out/fir/${tag}/capture.txt", cap);
saveText("out/fir/${tag}/last-write.txt", last);
saveText("out/fir/${tag}/recent-interesting-writes.txt", recent);
saveText("out/fir/${tag}/read-block-responses.txt", cap.readBlockResponses);
saveCaptureReadBlocks(cap, "out/fir/${tag}/read-blocks");

print("fir-ind-external-fir-impulse-load-capture-done");
print(last);
print(recent);
