let tag = "fir-upload-strong-ramp-good-offsets-first";
let base = "out/fir/${tag}";

connect();
resetSession();
ensureSession();
handshake();

let before = readSaveConfig("${base}/before", 0x00, 0x1F);

let upload = fir408UploadTestFir(0x00, "strong-ramp", "ramp10x_");
saveText("${base}/upload-strong-ramp.md", upload);

let good = fir408Cmd56ReadonlyOffsets(
    "${base}/cmd56-good",
    0x00,
    "0,1,2,13,14,15,38,39,40,41,150,157,158,177,195,196,197",
    1
);
saveText("${base}/cmd56-good-summary.md", good);

let afterGood = readSaveConfig("${base}/after-good", 0x00, 0x1F);
saveDiffReport("${base}/before-after-good-config-diff.md", assembledData(before), assembledData(afterGood));

let timeout = fir408Cmd56ReadonlyOffsets(
    "${base}/cmd56-timeout-candidates",
    0x00,
    "16,19,20,21,22",
    1
);
saveText("${base}/cmd56-timeout-candidates-summary.md", timeout);

print("fir-upload-strong-ramp-good-offsets-first-done");
print("saved=${base}");
