let tag = "ina-gate-attack-auto";

guiConnect();

let cap = guiActionCapture(
    "Move only the InA gate attack control once. The capture will auto-finish after the real GUI action settles.",
    45000,
    1200,
    6000
);

let last = lastWriteExcluding(cap, 0x40);
let recent = recentWritesExcluding(cap, 10, 0x40);
let readCount = len(cap.readBlockResponses);

saveText("out/clean/${tag}/summary.txt",
    "tag=${tag}\n"
    + "frames=" + cap.totalFrames + "\n"
    + "writes=" + cap.writeCount + "\n"
    + "responses=" + cap.responseCount + "\n"
    + "lastInteresting=" + last + "\n"
    + "readBlockResponses=" + readCount + "\n"
);

saveText("out/clean/${tag}/last-write.txt", last);
saveText("out/clean/${tag}/recent-interesting-writes.txt", recent);

if (readCount > 0) {
    saveCaptureReadBlocks(cap, "out/clean/${tag}/blocks");
}

print("done");
print(last);
